{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VM Compatibility Tool",
  "version": "0.1.0",
  "identifier": "com.vmct.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "VM Compatibility Tool",
        "width": 1100,
        "height": 750,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": ["icons/icon.ico"],
    "windows": {
      "requestedExecutionLevel": "requireAdministrator"
    }
  }
}
