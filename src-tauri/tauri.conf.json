{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VM Compatibility Tool",
  "version": "0.1.0",
  "identifier": "com.vmct.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "VM Compatibility Tool",
        "width": 660,
        "height": 640,
        "minWidth": 560,
        "minHeight": 560,
        "resizable": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": ["icons/icon.ico"]
  }
}
